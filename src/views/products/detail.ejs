<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<main>
  <div class="product-detail">
    <div class="product-detail-info">
      <h1><%= product.title %></h1>
      <p class="product-seller">Sold by <%= product.seller_name %></p>
      <p class="product-price">$<%= product.price %></p>
      <p class="product-category">Category: <%= product.category_name %></p>
      <p class="product-stock">In Stock: <%= product.stock_quantity %></p>
      <p class="product-description"><%= product.description %></p>

      <% if (user && user.role === 'buyer') { %>
        <form action="/cart/add" method="POST">
          <input type="hidden" name="productId" value="<%= product.id %>">
          <div class="form-group">
            <label for="quantity">Quantity</label>
            <input type="number" id="quantity" name="quantity" value="1" min="1" max="<%= product.stock_quantity %>">
          </div>
          <button type="submit" class="btn btn-primary">Add to Cart</button>
        </form>
      <% } else if (!user) { %>
        <p><a href="/auth/login">Login</a> to purchase this item.</p>
      <% } %>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>