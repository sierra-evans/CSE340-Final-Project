<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<main>
  <div class="product-detail">
    <div class="product-detail-info">
      <% if (product.image_url) { %>
        <img src="<%= product.image_url %>" alt="<%= product.title %>" class="product-detail-image" />
      <% } else { %>
        <div class="product-image-placeholder-lg">🌿</div>
      <% } %>
      <h1><%= product.title %></h1>
      <p class="product-seller">Sold by <%= product.seller_name %></p>
      <p class="product-price">$<%= product.price %></p>
      <p class="product-category">Category: <%= product.category_name %></p>
      <p class="product-stock">In Stock: <%= product.stock_quantity %></p>
      <p class="product-description"><%= product.description %></p>

      <% if (user && user.role === 'buyer') { %>
        <form action="/cart/add" method="POST">
          <input type="hidden" name="productId" value="<%= product.id %>">
          <div class="form-group">
            <label for="quantity">Quantity</label>
            <input type="number" id="quantity" name="quantity" value="1" min="1" max="<%= product.stock_quantity %>">
          </div>
          <button type="submit" class="btn btn-primary">Add to Cart</button>
        </form>
      <% } else if (!user) { %>
        <p><a href="/auth/login">Login</a> to purchase this item.</p>
      <% } %>
    </div>
  </div>

  <!-- Reviews Section -->
  <div class="reviews-section">
    <h2>Reviews</h2>

    <% if (reviews.length === 0) { %>
      <p>No reviews yet. Be the first to leave one!</p>
    <% } else { %>
      <div class="reviews-list">
        <% reviews.forEach(review => { %>
          <div class="review-card">
            <div class="review-header">
              <span class="review-author"><%= review.reviewer_name %></span>
              <span class="review-rating">
                <% for(let i = 1; i <= 5; i++) { %>
                  <span class="<%= i <= review.rating ? 'star-filled' : 'star-empty' %>">★</span>
                <% } %>
              </span>
            </div>
            <p class="review-comment"><%= review.comment %></p>
            <p class="review-date"><%= new Date(review.created_at).toLocaleDateString() %></p>

            <% if (user && user.id === review.user_id) { %>
              <div class="review-actions">
                <a href="/reviews/<%= review.id %>/edit?productId=<%= product.id %>" class="btn btn-outline">Edit</a>
                <form action="/reviews/<%= review.id %>/delete" method="POST" style="display:inline;">
                  <input type="hidden" name="productId" value="<%= product.id %>">
                  <button type="submit" class="btn btn-danger">Delete</button>
                </form>
              </div>
            <% } %>

            <% if (user && user.role === 'admin') { %>
              <div class="review-actions">
                <form action="/admin/reviews/<%= review.id %>/delete" method="POST" style="display:inline;">
                  <input type="hidden" name="productId" value="<%= product.id %>">
                  <button type="submit" class="btn btn-danger">Remove Review</button>
                </form>
              </div>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } %>

    <!-- Leave a Review Form -->
    <% if (user && user.role === 'buyer') { %>
      <div class="review-form">
        <h3>Leave a Review</h3>
        <form action="/reviews" method="POST">
          <input type="hidden" name="productId" value="<%= product.id %>">

          <div class="form-group">
            <label for="rating">Rating</label>
            <select id="rating" name="rating" required>
              <option value="">Select a rating</option>
              <option value="5">★★★★★ (5/5)</option>
              <option value="4">★★★★☆ (4/5)</option>
              <option value="3">★★★☆☆ (3/5)</option>
              <option value="2">★★☆☆☆ (2/5)</option>
              <option value="1">★☆☆☆☆ (1/5)</option>
            </select>
          </div>

          <div class="form-group">
            <label for="comment">Comment</label>
            <textarea id="comment" name="comment" rows="4" required placeholder="Share your thoughts about this product..."></textarea>
          </div>

          <button type="submit" class="btn btn-primary">Submit Review</button>
        </form>
      </div>
    <% } %>
  </div>
</main>

<%- include('../partials/footer') %>